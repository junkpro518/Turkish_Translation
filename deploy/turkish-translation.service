[Unit]
Description=Arabic Turkish Translation Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/projects/turkish-translation
EnvironmentFile=/opt/projects/turkish-translation/.env
ExecStart=/opt/projects/turkish-translation/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
